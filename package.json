{
  "name": "giopic",
  "productName": "GioPic",
  "type": "module",
  "version": "0.0.1",
  "description": "Desktop image uploader with plugin-based storage providers.",
  "author": "isYangs",
  "github": "https://github.com/isYangs/GioPic",
  "license": "AGPL-3.0",
  "license-file": "LICENSE",
  "main": "dist-electron/main/index.js",
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:3344/"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm run build:desktop",
    "build:app": "pnpm run build:plugins && pnpm run typecheck:app && vite build",
    "build:desktop": "pnpm run build:app && electron-builder",
    "build:desktop:win": "pnpm run build:app && electron-builder --win",
    "build:desktop:mac": "pnpm run build:app && electron-builder --mac",
    "build:win": "pnpm run build:desktop:win",
    "build:mac": "pnpm run build:desktop:mac",
    "build:plugins": "pnpm --filter @giopic/* run build",
    "changeset": "changeset",
    "changeset:add": "changeset add",
    "changeset:version": "changeset version",
    "changeset:release": "changeset publish",
    "version:app": "node scripts/bump-app-version.mjs",
    "version:app:patch": "node scripts/bump-app-version.mjs patch",
    "version:app:minor": "node scripts/bump-app-version.mjs minor",
    "version:app:major": "node scripts/bump-app-version.mjs major",
    "version:app:beta": "node scripts/bump-app-version.mjs prerelease --preid=beta",
    "version:app:rc": "node scripts/bump-app-version.mjs prerelease --preid=rc",
    "release:app:patch": "node scripts/bump-app-version.mjs patch --git-commit --git-tag",
    "release:app:minor": "node scripts/bump-app-version.mjs minor --git-commit --git-tag",
    "release:app:major": "node scripts/bump-app-version.mjs major --git-commit --git-tag",
    "release:app:beta": "node scripts/bump-app-version.mjs prerelease --preid=beta --git-commit --git-tag",
    "release:app:rc": "node scripts/bump-app-version.mjs prerelease --preid=rc --git-commit --git-tag",
    "version:plugins": "node scripts/bump-plugins.mjs",
    "version:plugins:patch": "node scripts/bump-plugins.mjs patch",
    "version:plugins:minor": "node scripts/bump-plugins.mjs minor",
    "version:plugins:major": "node scripts/bump-plugins.mjs major",
    "version:plugins:beta": "node scripts/bump-plugins.mjs prerelease --preid=beta",
    "version:plugins:rc": "node scripts/bump-plugins.mjs prerelease --preid=rc",
    "version:plugins:release": "node scripts/bump-plugins.mjs patch --git-commit --git-tag",
    "publish:plugins": "node scripts/publish-plugins.mjs --tag=latest",
    "publish:plugins:dry": "node scripts/publish-plugins.mjs --tag=latest --dry-run",
    "publish:plugins:next": "node scripts/publish-plugins.mjs --tag=next",
    "publish:plugins:next:dry": "node scripts/publish-plugins.mjs --tag=next --dry-run",
    "release:plugins:patch": "node scripts/bump-plugins.mjs patch --git-commit --git-tag && node scripts/publish-plugins.mjs --tag=latest",
    "release:plugins:minor": "node scripts/bump-plugins.mjs minor --git-commit --git-tag && node scripts/publish-plugins.mjs --tag=latest",
    "release:plugins:major": "node scripts/bump-plugins.mjs major --git-commit --git-tag && node scripts/publish-plugins.mjs --tag=latest",
    "release:plugins:beta": "node scripts/bump-plugins.mjs prerelease --preid=beta --git-commit --git-tag && node scripts/publish-plugins.mjs --tag=next",
    "release:plugins:rc": "node scripts/bump-plugins.mjs prerelease --preid=rc --git-commit --git-tag && node scripts/publish-plugins.mjs --tag=next",
    "postinstall": "pnpm run build:plugins",
    "devtools": "pnpm vue-devtools",
    "preview": "vite preview",
    "lint": "node scripts/run-eslint.mjs .",
    "lint:fix": "node scripts/run-eslint.mjs . --fix",
    "typecheck": "pnpm run typecheck:app && pnpm run typecheck:packages",
    "typecheck:app": "vue-tsc --noEmit",
    "typecheck:packages": "pnpm --filter @giopic/core --filter @giopic/lsky-plugin --filter @giopic/lskypro-plugin --filter @giopic/s3-plugin run typecheck",
    "test": "pnpm run test:unit",
    "test:run": "pnpm run test:unit:run",
    "test:ui": "pnpm run test:unit:ui",
    "test:coverage": "pnpm run test:unit:coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:unit": "vitest --config vitest.config.ts",
    "test:unit:run": "vitest run --config vitest.config.ts",
    "test:unit:ui": "vitest --ui --config vitest.config.ts",
    "test:unit:coverage": "vitest run --coverage --config vitest.config.ts",
    "test:integration": "pnpm --filter @giopic/integration-tests test",
    "test:integration:run": "pnpm --filter @giopic/integration-tests test:run",
    "test:integration:ui": "pnpm --filter @giopic/integration-tests test:ui",
    "test:integration:coverage": "pnpm --filter @giopic/integration-tests test:coverage",
    "verify": "pnpm lint && pnpm run typecheck && pnpm run test:unit:run && pnpm run test:integration:run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1021.0",
    "@aws-sdk/lib-storage": "^3.1021.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@giopic/core": "workspace:^",
    "@giopic/lsky-plugin": "workspace:^",
    "@giopic/s3-plugin": "workspace:^",
    "@vueuse/core": "^13.2.0",
    "animate.css": "^4.1.1",
    "axios": "^1.14.0",
    "dayjs": "^1.11.20",
    "electron-better-ipc": "^2.0.1",
    "electron-log": "^5.4.3",
    "electron-store": "^10.0.1",
    "electron-updater": "^6.8.3",
    "mime": "^4.0.7",
    "p-limit": "^6.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate-2": "^2.0.32",
    "radash": "^12.1.1",
    "sharp": "^0.34.5",
    "vue": "^3.5.31",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.13.1",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@iconify/json": "^2.2.458",
    "@iconify/vue": "^5.0.0",
    "@playwright/test": "^1.54.2",
    "@types/node": "^24.12.0",
    "@unocss/eslint-config": "^66.6.7",
    "@unocss/eslint-plugin": "^66.6.7",
    "@unocss/preset-rem-to-px": "^66.6.7",
    "@unocss/reset": "^66.6.7",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "bumpp": "^10.4.1",
    "electron": "^36.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.27.0",
    "eslint-plugin-format": "^1.0.1",
    "happy-dom": "^20.8.9",
    "naive-ui": "^2.44.1",
    "playwright": "^1.54.2",
    "tsdown": "^0.12.0",
    "typescript": "^5.8.3",
    "unocss": "^66.6.7",
    "unplugin-auto-import": "^19.2.0",
    "unplugin-vue-components": "^28.5.0",
    "unplugin-vue-router": "^0.12.0",
    "vfonts": "^0.0.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-vue-devtools": "^7.7.6",
    "vitest": "^4.1.2",
    "vue-tsc": "^2.2.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
