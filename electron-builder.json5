{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.giopic.app",
  "asar": true,
  "productName": "GioPic",
  "directories": {
    "output": "release/${version}"
  },
  "files": [
    "dist",
    "dist-electron",
    "dist-native",
    "node_modules/@giopic",
    "web"
  ],
  "mac": {
    // Use ad-hoc signing so macOS builds do not require Apple Developer certificates.
    "identity": "-",
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "zip",
        "arch": ["x64", "arm64"]
      }
    ],
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "icon": "public/icon-mac.png"
  },
  "dmg": {
    "icon": "public/icon-mac.png",
    "iconSize": 100,
    "background": "public/dmg-background.png",
    "contents": [
      {
        "x": 615,
        "y": 379,
        "type": "link",
        "path": "/Applications"
      },
      {
        "x": 165,
        "y": 375,
        "type": "file"
      }
    ],
    "window": {
      "width": 810,
      "height": 600
    }
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64", "arm64"]
      }
    ],
    "artifactName": "${productName}-${version}-${arch}-setup.${ext}",
    "icon": "public/icon.ico"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false
  },
  "publish": {
    "provider": "github",
    "owner": "isYangs",
    "repo": "GioPic"
  }
}
